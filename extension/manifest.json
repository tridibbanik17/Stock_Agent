{
  "manifest_version": 3,
  "name": "Stock Agent",
  "version": "0.1.1",
  "description": "A privacy-first stock dashboard that blends AI context with fundamentals to expose value traps and automate your watchlist reports.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Stock Agent",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://api.stockagent.app/*",
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
