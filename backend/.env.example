# Supabase → Project Settings → Data API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Server-side only (sb_secret_... or legacy service_role JWT)
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxx

# Optional client/publishable key (sb_publishable_... or legacy anon JWT)
# Not used by the FastAPI upsert path — kept for future browser-safe reads.
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxx

# Resend (https://resend.com) — leave blank to dry-run / log reports in cron
RESEND_API_KEY=re_secret_xxxxxxxx
REPORT_FROM_EMAIL=Stock Agent <onboarding@resend.dev>

HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
